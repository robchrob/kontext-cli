# .ktxrc — ktx configuration
# vim:set et ft=toml sw=4 ts=4:
# ktx by default searches upward from target directory for .ktxrc
# Override with: ktx -c path/to/.ktxrc.custom

# ── Global settings ───────────────────────────────
# Default type when .type not specified on CLI
type=api

# Token budget (skip / 0 = unlimited)
limit=100000

# ── Output customization ──────────────────────────
# Set strings to empty to disable them from printing
instruction-header=Output full name + extension on the line before each code block.
context-heading=## Context for %s
tree-heading=### Directory Tree
file-header=### %s
agents-file=AGENTS.md

# ── Modifiers (applied to the active type) ────────
# +ITEM includes files matching glob/name
# -ITEM removes from includes (globs) or stops excluding a directory (names)
+*.sql,Makefile
-*.md

# ── Custom types: pattern-based ───────────────────
# Use include= and exclude= for glob-based file discovery
# Use with= to compose types (merges include/exclude from dependencies)
[type:docs]
include=*.md *.rst *.txt *.adoc
exclude=build _build site

[type:go]
include=*.go *.mod *.sum *.json *.yml *.yaml *.md *.toml
exclude=vendor dist build

[type:rs]
include=*.rs *.toml *.json *.yml *.yaml *.md
exclude=target dist build

[type:c]
include=*.c *.h *.cpp *.hpp *.cc *.cxx *.cmake *.json *.yaml *.md
exclude=build .cache out

[type:java]
include=*.java *.xml *.gradle *.properties *.yml *.yaml *.md
exclude=.gradle build target out

# ── Pattern type composition ──────────────────────
# with= merges include/exclude from depended types
[type:fullstack]
with=js
include=*.py *.toml Dockerfile
exclude=__pycache__ .venv

# ── Custom types: file lists ─────────────────────
# List explicit file paths (one per line) for domain slicing.
# Use with= to compose types (e.g. always include shared/infra files).
[type:api]
with=infra
src/api/routes.ts
src/api/middleware.ts
src/api/auth.ts

[type:infra]
src/db/schema.ts
src/db/index.ts
src/lib/utils.ts
tsconfig.json
package.json
