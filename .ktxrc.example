# .ktxrc — ktx configuration
# vim:set et ft=toml sw=4 ts=4:
# ktx searches upward from target directory for .ktxrc
# Override with: ktx -c path/to/config

# ── Global settings ───────────────────────────────
# Default type when .type not specified on CLI
type=py

# Token budget (0 = unlimited)
limit=100000

# Custom instruction header (empty string disables it)
agent-header=Focus on security and error handling.

# ── Modifiers (applied to the active type) ────────
# Globs add to include patterns; plain names add to excluded dirs
+*.sql,Makefile
-*.md

# ── Custom types: pattern-based ───────────────────
# Use include= and exclude= for glob-based file discovery
[type:docs]
include=*.md *.rst *.txt *.adoc
exclude=build _build site

[type:go]
include=*.go *.mod *.sum *.json *.yml *.yaml *.md *.toml Makefile Dockerfile
exclude=vendor dist build

[type:rs]
include=*.rs *.toml *.json *.yml *.yaml *.md Makefile Dockerfile
exclude=target dist build

[type:c]
include=*.c *.h *.cpp *.hpp *.cc *.cxx *.cmake *.json *.yaml *.md Makefile CMakeLists.txt
exclude=build .cache out

[type:java]
include=*.java *.xml *.gradle *.properties *.yml *.yaml *.md
exclude=.gradle build target out

# ── Custom types: file lists ─────────────────────
# List explicit file paths (one per line) for domain slicing.
# Use with= to compose types (e.g. always include shared/infra files).
[type:api]
with=infra
src/api/routes.ts
src/api/middleware.ts
src/api/auth.ts

[type:infra]
src/db/schema.ts
src/db/index.ts
src/lib/utils.ts
tsconfig.json
package.json
