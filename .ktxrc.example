# .ktxrc — ktx configuration
# vim:set et ft=toml sw=4 ts=4:
# ktx searches upward from target dir for .ktxrc
# Override with: ktx -c path/to/.ktxrc.custom

# ── Global settings ───────────────────────────
# Default type when .type not specified on CLI
type=api

# Token budget (0 or omit = unlimited)
limit=1000000

# ── Output customization ─────────────────────
# Set to empty string to disable
instruction-header=Output full filename + extension in line before each code block.

# Agents file (empty string disables agents ingest)
agents-file=AGENTS.md

# ── Modifiers (applied to the active type) ────
# +ITEM includes files matching glob/name
# -ITEM removes from includes or adds dir to prune
+*.sql,Makefile
-*.md

# ── Custom types: pattern-based ───────────────
# include= selects files by glob
# exclude= prunes directories
# with= composes types (merges include/exclude)
[type:docs]
include=*.md *.rst *.txt *.adoc
exclude=build _build site

# ── Pattern type composition ──────────────────
# with= merges include/exclude from dependencies
[type:fullstack]
with=js
include=*.py *.toml Dockerfile
exclude=__pycache__ .venv

# ── Custom types: file lists ─────────────────
# Explicit file paths (one per line).
# with= composes types (always include shared files)
[type:api]
with=infra
src/api/routes.ts
src/api/middleware.ts
src/api/auth.ts

[type:infra]
src/db/schema.ts
src/db/index.ts
src/lib/utils.ts
tsconfig.json
package.json
