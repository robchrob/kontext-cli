#!/usr/bin/env bash
set -euo pipefail

# ── Filter Presets ──────────────────────────────────────────────────
declare -A EXCLUDE_DIRS=(
  [default]='.git .svn .hg .DS_Store node_modules dist build out .idea .vscode .vs coverage'
  [js]='node_modules .next .nuxt .turbo bower_components dist build out .idea .vscode coverage .nyc_output'
  [py]='__pycache__ .venv venv .env .mypy_cache .pytest_cache .ruff_cache .tox *.egg-info htmlcov dist build .idea .vscode'
  [go]='vendor .idea .vscode dist build'
  [rs]='target .idea .vscode dist build'
  [c]='.git .cache build out compile_commands.json .idea .vscode'
  [java]='.gradle build target .idea .vscode out'
)
declare -A INCLUDE_PATTERNS=(
  [default]='*'
  [js]='*.js *.ts *.jsx *.tsx *.mjs *.cjs *.json *.html *.css *.scss *.svelte *.vue *.md'
  [py]='*.py *.pyw *.pyi *.toml *.cfg *.ini *.json *.yml *.yaml *.md *.txt *.rst *.j2 Makefile Dockerfile'
  [go]='*.go *.mod *.sum *.json *.yml *.yaml *.md *.toml Makefile Dockerfile'
  [rs]='*.rs *.toml *.json *.yml *.yaml *.md Makefile Dockerfile'
  [c]='*.c *.h *.cpp *.hpp *.cc *.cxx *.hh *.inl Makefile CMakeLists.txt *.cmake *.json *.yml *.yaml *.md'
  [java]='*.java *.xml *.gradle *.properties *.yml *.yaml *.md'
)

# Files excluded by name/glob regardless of type (binary, media, locks, artifacts)
GLOBAL_EXCLUDE_FILES='*.min.js *.min.css *.map *.lock package-lock.json yarn.lock pnpm-lock.yaml *.png *.jpg *.jpeg *.gif *.ico *.svg *.webp *.woff *.woff2 *.ttf *.eot *.otf *.pyc *.pyo *.so *.dylib *.dll *.o *.a *.class *.jar *.zip *.tar.gz *.tgz *.rar *.7z *.db *.sqlite *.sqlite3 *.log *.pid'

declare -A EXT_CNT=() EXT_TOK=()

# Token budget (0 = unlimited)
MAX_TOKENS=0

tok_est() {
  local b w
  b=$(wc -c <"$1")
  w=$(wc -w <"$1")
  echo $(( b*100/680 + w*65/100 ))
}

tok_est_str() {
  local b w
  b=${1:-0}
  w=${2:-0}
  echo $(( b*100/680 + w*65/100 ))
}

fmt_num() {
  case "$1" in
    ''|*[!0-9]*) printf '%s' "$1";;
    *) if command -v numfmt >/dev/null 2>&1; then LC_NUMERIC=C numfmt --grouping "$1" 2>/dev/null || printf '%s' "$1"; else printf '%s' "$1"; fi;;
  esac
}

_add_word() {
  local cur="$1" token="$2" w
  for w in $cur; do [[ "$w" == "$token" ]] && { printf '%s' "$cur"; return; }; done
  printf '%s %s' "$cur" "$token"
}

_remove_word() {
  local cur="$1" token="$2" out= w
  for w in $cur; do [[ "$w" == "$token" ]] || out="$out $w"; done
  echo "${out#"${out%%[! ]*}"}"
}

apply_mods() {
  local type="$1"; shift
  local m body part token target
  for m in "$@"; do
    body=${m:1}
    IFS=',' read -r -a parts <<<"$body"
    for part in "${parts[@]}"; do
      token="${part#"${part%%[![:space:]]*}"}"
      token="${token%"${token##*[![:space:]]}"}"
      [[ -z $token ]] && continue
      if [[ $token == *[\*\?\[]* || $token == Makefile || $token == Dockerfile || $token == CMakeLists.txt ]]; then
        target=include
      else
        target=exclude
      fi
      if [[ ${m:0:1} == '+' ]]; then
        if [[ $target == include ]]; then
          INCLUDE_PATTERNS["$type"]=$(_add_word "${INCLUDE_PATTERNS[$type]-}" "$token")
        else
          EXCLUDE_DIRS["$type"]=$(_add_word "${EXCLUDE_DIRS[$type]-}" "$token")
        fi
      else
        if [[ $target == include ]]; then
          INCLUDE_PATTERNS["$type"]=$(_remove_word "${INCLUDE_PATTERNS[$type]-}" "$token")
        else
          EXCLUDE_DIRS["$type"]=$(_remove_word "${EXCLUDE_DIRS[$type]-}" "$token")
        fi
      fi
    done
  done
}

load_ctxrc() {
  local dir=$1
  local ctxrc="$dir/.ctxrc"
  [[ -f $ctxrc ]] || return 0
  
  while IFS='=' read -r key val; do
    [[ -z $key || $key == \#* ]] && continue
    val=${val#"${val%%[![:space:]]*}"}; val=${val%"${val##*[![:space:]]}"}
    case "$key" in
      type) type_from_rc=$val ;;
      max-tokens) MAX_TOKENS=$val ;;
      +*) apply_mods "${type_from_rc:-default}" "$key=$val" ;;
      -*) apply_mods "${type_from_rc:-default}" "$key=$val" ;;
    esac
  done < "$ctxrc"
}

show_stats() {
  if (( ${#EXT_TOK[@]} == 0 )); then return; fi
  local header max ext cnt tok f w
  header="Tokens"

  max=${#header}
  for ext in "${!EXT_TOK[@]}"; do
    (( ${#ext} > max )) && max=${#ext}
  done
  for tok in "${EXT_TOK[@]}"; do
    f=$(fmt_num "$tok")
    (( ${#f} > max )) && max=${#f}
  done
  (( max < 9 )) && max=9

  printf '%-*s | Files | %s\n' "$max" "Extension" "$header" >&2
  local sep=""
  for ((i=0; i<max; i++)); do sep+="-"; done
  printf '%s-|-------|-\n' "$sep" >&2

  for ext in "${!EXT_TOK[@]}"; do
    printf '%s\t%d\t%d\n' "$ext" "${EXT_CNT["$ext"]}" "${EXT_TOK["$ext"]}"
  done | sort -t$'\t' -k3,3nr |
  while IFS=$'\t' read -r ext cnt raw; do
    printf '%-*s | %5d | %*s\n' "$max" "$ext" "$cnt" "${#header}" "$(fmt_num "$raw")" >&2
  done
}

is_globally_excluded() {
  local base="$1" pat
  for pat in $GLOBAL_EXCLUDE_FILES; do
    case "$base" in $pat) return 0 ;; esac
  done
  return 1
}

usage() {
  cat >&2 <<'EOF'
Usage: ctx [options] [modifiers...] [directory][.type]

Options:
  -o, --output <file>   write to file
  -t, --tree            prepend directory tree (default: on)
  -T, --no-tree         disable tree
  -m, --max-tokens N    stop when token budget reached
  --no-clip             skip clipboard
  -h, --help            help

Modifiers:
  +PAT[,PAT...]  add patterns (globs → include, names → exclude)
  -PAT[,PAT...]  remove patterns

Types:
EOF
  for k in $(printf '%s\n' "${!INCLUDE_PATTERNS[@]}" | sort); do
    printf '  .%-10s include: %s\n' "$k" "${INCLUDE_PATTERNS[$k]}" >&2
  done
  cat >&2 <<'EOF'

Examples:
  ctx                        # current dir, default type, tree on
  ctx .py                    # current dir as Python project
  ctx src/.js                # src/ as JavaScript project
  ctx +'Makefile' -'*.md' .  # add Makefile, drop markdown
  ctx -m 50000 .py           # limit output to ~50k tokens

Config (.ctxrc):
  type=py
  +Makefile,*.sql
  -*.md
  max-tokens=100000
EOF
}

copy_to_clipboard() {
  local content="$1"
  
  if command -v pbcopy >/dev/null 2>&1; then
    printf '%s' "$content" | pbcopy && return 0
  elif command -v wl-copy >/dev/null 2>&1; then
    printf '%s' "$content" | wl-copy && return 0
  elif command -v xclip >/dev/null 2>&1; then
    printf '%s' "$content" | xclip -selection clipboard && return 0
  elif command -v xsel >/dev/null 2>&1; then
    printf '%s' "$content" | xsel --clipboard --input && return 0
  elif command -v clip >/dev/null 2>&1; then
    printf '%s' "$content" | clip && return 0
  fi
  return 1
}

get_git_ignored() {
  local dir=$1
  git -C "$dir" ls-files -oi --exclude-standard --directory 2>/dev/null | sed 's~/$~~' || true
}

run_tree() {
  local dir=$1 type=$2

  if command -v tree-git-ignore >/dev/null 2>&1; then
    printf '### Directory Tree\n'
    tree-git-ignore -a --noreport --prune "$dir" || true
    printf '\n'
    return
  fi

  if ! command -v tree >/dev/null 2>&1; then
    printf '### (Warning: "tree" not found, skipping tree view)\n\n'
    return
  fi

  printf '### Directory Tree\n'

  local tree_opts=(-a --noreport --prune)
  local ignore_pat=""

  if [[ -n "${EXCLUDE_DIRS[$type]-}" ]]; then
    ignore_pat="${EXCLUDE_DIRS[$type]// /|}"
  fi

  if git -C "$dir" rev-parse --is-inside-work-tree &>/dev/null; then
    local git_ignored
    git_ignored=$(get_git_ignored "$dir")
    if [[ -n "$git_ignored" ]]; then
      local git_pat
      git_pat=$(echo "$git_ignored" | tr '\n' '|')
      if [[ -n "$ignore_pat" ]]; then
        ignore_pat+="|$git_pat"
      else
        ignore_pat="$git_pat"
      fi
    fi
  fi

  ignore_pat=${ignore_pat%│}
  if [[ -n "$ignore_pat" ]]; then
    tree_opts+=(-I "$ignore_pat")
  fi

  tree "${tree_opts[@]}" "$dir" || true
  printf '\n'
}

run_find() {
  local dir=$1 type=$2
  local -a args=("find" "$dir")
  local git_ignored=""
  
  if git -C "$dir" rev-parse --is-inside-work-tree &>/dev/null; then
    git_ignored=$(get_git_ignored "$dir")
  fi

  set -f
  [[ -n "${EXCLUDE_DIRS[$type]-}" ]] && {
    args+=(\()
    local first=1 d
    for d in ${EXCLUDE_DIRS[$type]}; do
      (( first )) || args+=(-o)
      first=0
      args+=(-name "$d")
    done
    args+=(\) -prune -o)
  }

  args+=(-type f)
  if [[ "${INCLUDE_PATTERNS[$type]}" != "*" ]]; then
    args+=(\()
    local first=1 pat
    for pat in ${INCLUDE_PATTERNS[$type]}; do
      (( first )) || args+=(-o)
      first=0
      args+=(-name "$pat")
    done
    args+=(\))
  fi
  set +f

  args+=(-print0)

  local total_bytes=0 total_words=0

  while IFS= read -r -d '' file; do
    [[ ! -s "$file" ]] && continue

    local base ext
    base=${file##*/}

    is_globally_excluded "$base" && continue
    
    if [[ -n "$git_ignored" ]]; then
      local rel="${file#$dir/}"
      if echo "$git_ignored" | grep -qxF "$rel"; then
        continue
      fi
    fi

    local fsize fwords
    fsize=$(wc -c <"$file")
    fwords=$(wc -w <"$file")
    total_bytes=$((total_bytes + fsize))
    total_words=$((total_words + fwords))

    if [[ $MAX_TOKENS -gt 0 ]]; then
      local est
      est=$(tok_est_str "$fsize" "$fwords")
      local running
      running=$(tok_est_str "$total_bytes" "$total_words")
      if (( running > MAX_TOKENS )); then
        printf '\n--- TOKEN BUDGET REACHED (%s tokens) ---\n' "$(fmt_num "$MAX_TOKENS")" >&2
        break
      fi
    fi

    [[ $base == *.* ]] && ext=.${base##*.} || ext=$base
    EXT_CNT[$ext]=$(( ${EXT_CNT[$ext]:-0} + 1 ))
    EXT_TOK[$ext]=$(( ${EXT_TOK[$ext]:-0} + $(tok_est "$file") ))
    local -a lines
    mapfile -n2 -t lines <"$file" 2>/dev/null || true

    if [[ ${lines[0]:-} != *"$file"* && ${lines[1]:-} != *"$file"* && ${lines[0]:-} != *"$base"* && ${lines[1]:-} != *"$base"* ]]; then
      printf '### %s\n' "$file"
    fi
    tr -d '\0' <"$file"; printf '\n\n'
  done < <("${args[@]}" 2>/dev/null)
}

main() {
  local out_file='' no_clip=false use_tree=true type_from_rc=''
  
  while [[ $# -gt 0 ]]; do
    case $1 in
      -h|--help) usage; exit 0 ;;
      -o|--output) [[ $# -gt 1 ]] && out_file=$2 || { usage; exit 1; }; shift 2 ;;
      --no-clip) no_clip=true; shift ;;
      -t|--tree) use_tree=true; shift ;;
      -T|--no-tree) use_tree=false; shift ;;
      -m|--max-tokens) [[ $# -gt 1 ]] && MAX_TOKENS=$2 || { usage; exit 1; }; shift 2 ;;
      *) break ;;
    esac
  done

  local -a MODS=()
  while [[ $# -gt 0 && ( $1 == +* || $1 == -* ) ]]; do
    MODS+=("$1")
    shift
  done

  local input="${1:-.}"
  [[ $# -gt 1 ]] && shift
  while [[ $# -gt 0 && ( $1 == +* || $1 == -* ) ]]; do
    MODS+=("$1")
    shift
  done

  local dir type
  dir=${input%.*}; type=${input##*.}
  [[ -z $dir ]] && dir='.'
  [[ -z $type || $type == "$dir" ]] && type=default
  [[ -d $dir ]] || { echo "Directory '$dir' not found" >&2; exit 1; }
  [[ ${INCLUDE_PATTERNS[$type]+_} ]] || { echo "Unknown type '.$type'" >&2; exit 1; }

  load_ctxrc "$dir"
  [[ -n $type_from_rc && -z "${MODS[*]}" ]] && type="$type_from_rc"
  (( ${#MODS[@]} )) && apply_mods "$type" "${MODS[@]}"

  local tmp; tmp=$(mktemp)
  local full_path
  full_path=$(cd "$dir" && pwd)

  printf 'Please state the full filename with its extension in the line immediately preceding each code block!\n\n' >> "$tmp"
  printf '## Context for %s\n' "$full_path" >> "$tmp"

  if $use_tree; then
    run_tree "$dir" "$type" >> "$tmp"
  fi

  if [[ -f "$dir/AGENTS.md" ]]; then
    printf '### System Prompt (from AGENTS.md)\n' >> "$tmp"
    cat "$dir/AGENTS.md" >> "$tmp"
    printf '\n\n' >> "$tmp"
  fi

  run_find "$dir" "$type" >>"$tmp"

  local content; content=$(<"$tmp"); rm -f "$tmp"
  [[ -z $content ]] && { echo "No files found" >&2; exit 0; }
  local dests=()
  if ! $no_clip; then
    if copy_to_clipboard "$content"; then
      dests+=(clipboard)
    fi
  fi
  if [[ -n $out_file ]]; then printf '%s' "$content" >"$out_file"; dests+=("$out_file"); fi
  [[ ${#dests[@]} -eq 0 ]] && dests+=(stdout)

  show_stats

  local raw_total total
  raw_total=$(( $(printf '%s' "$content" | wc -c)*100/680 + $(printf '%s' "$content" | wc -w)*65/100 ))

  if (( raw_total > 1000000 )); then
    printf 'WARNING: Content exceeds 1M tokens (~%s)\n' "$(fmt_num "$raw_total")" >&2
  fi

  total=$(fmt_num "$raw_total")
  echo "Context for '$dir' (type: $type) → ${dests[*]} (~$total tokens)" >&2
  [[ ${dests[*]} == *stdout* ]] && printf '%s' "$content"
}

main "$@"
