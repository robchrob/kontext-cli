#!/usr/bin/env bash
set -feuo pipefail

VERSION="0.1.1"

declare -A EXCLUDE_DIRS=(
  [default]=''
  [js]='node_modules .next .nuxt .turbo bower_components dist build out coverage .nyc_output'
  [py]='__pycache__ .venv venv .mypy_cache .pytest_cache .ruff_cache .tox *.egg-info htmlcov dist build'
  [go]='vendor dist build'
  [rs]='target dist build'
  [c]='build .cache out'
  [java]='.gradle build target out'
)
declare -A INCLUDE_PATTERNS=(
  [default]='*'
  [js]='*.js *.ts *.jsx *.tsx *.mjs *.cjs *.json *.html *.css *.scss *.svelte *.vue *.md'
  [py]='*.py *.pyw *.pyi *.toml *.cfg *.ini *.json *.yml *.yaml *.md *.txt *.rst *.j2 Makefile Dockerfile'
  [go]='*.go *.mod *.sum *.json *.yml *.yaml *.md *.toml Makefile Dockerfile'
  [rs]='*.rs *.toml *.json *.yml *.yaml *.md Makefile Dockerfile'
  [c]='*.c *.h *.cpp *.hpp *.cc *.cxx *.hh *.inl *.cmake *.json *.yml *.yaml *.md Makefile CMakeLists.txt'
  [java]='*.java *.xml *.gradle *.properties *.yml *.yaml *.md'
)

BASE_EXCLUDE_DIRS='.git .svn .hg .idea .vscode .vs'

GLOBAL_EXCLUDE_FILES=(
  .DS_Store Thumbs.db desktop.ini .env '.env.*' .envrc
  '*.pem' '*.key' '*.p12' '*.pfx' '*.keystore' '*.jks'
  .npmrc .netrc .htpasswd 'id_rsa*' 'id_ed*'
  '*.secret' '*.credentials' '*.tfvars' '*.tfstate' '*.tfstate.*'
  '*.pyc' '*.pyo' '*.so' '*.dylib' '*.dll' '*.o' '*.a' '*.obj'
  '*.class' '*.jar' '*.exe' '*.bin'
  '*.png' '*.jpg' '*.jpeg' '*.gif' '*.ico' '*.svg' '*.webp' '*.bmp' '*.tiff'
  '*.woff' '*.woff2' '*.ttf' '*.eot' '*.otf'
  '*.mp3' '*.mp4' '*.wav' '*.avi' '*.mov' '*.webm' '*.pdf'
  '*.zip' '*.gz' '*.tgz' '*.rar' '*.7z' '*.bz2' '*.xz'
  '*.lock' package-lock.json pnpm-lock.yaml
  '*.min.js' '*.min.css' '*.map'
  '*.db' '*.sqlite' '*.sqlite3' '*.log' '*.pid' '*.out'
  LICENSE LICENSE.md LICENSE.txt LICENCE LICENCE.md
  CHANGELOG CHANGELOG.md compile_commands.json AGENTS.md .ktxrc .ctxrc
)

for _k in "${!INCLUDE_PATTERNS[@]}"; do
  EXCLUDE_DIRS[$_k]="$BASE_EXCLUDE_DIRS ${EXCLUDE_DIRS[$_k]-}"
done
unset _k

declare -A EXT_CNT=() EXT_TOK=()
declare -A TYPE_FILES=()
declare -A TYPE_WITH=()
declare -a FORCE_INCLUDE=()
CONFIG_FILE=""
MAX_TOKENS=0
SHOW_IGNORED=false
RANDOM_ORDER=false
RAW_MODE=false
AGENT_HEADER="Please state the full filename with its extension in the line immediately preceding each code block!"
IGNORED_BY=''
SKIP_COUNT=0
FILE_COUNT=0

fmt_num() {
  case "$1" in
    ''|*[!0-9]*) printf '%s' "$1" ;;
    *)
      if command -v numfmt >/dev/null 2>&1; then
        LC_NUMERIC=C numfmt --grouping "$1" 2>/dev/null || printf '%s' "$1"
      else
        printf '%s' "$1"
      fi
      ;;
  esac
}

_add_word() {
  local cur="$1" token="$2" w
  for w in $cur; do
    [[ "$w" == "$token" ]] && { printf '%s' "$cur"; return; }
  done
  printf '%s %s' "$cur" "$token"
}

_remove_word() {
  local cur="$1" token="$2" out="" w
  for w in $cur; do
    [[ "$w" == "$token" ]] || out="$out $w"
  done
  echo "${out#"${out%%[! ]*}"}"
}

_is_known_include() {
  local token="$1" t p
  for t in "${!INCLUDE_PATTERNS[@]}"; do
    for p in ${INCLUDE_PATTERNS[$t]}; do
      [[ "$p" == "$token" ]] && return 0
    done
  done
  return 1
}

apply_mods() {
  local type="$1"; shift
  local m body part token is_include
  for m in "$@"; do
    body="${m:1}"
    IFS=',' read -r -a parts <<< "$body"
    for part in "${parts[@]}"; do
      token="${part#"${part%%[![:space:]]*}"}"
      token="${token%"${token##*[![:space:]]}"}"
      [[ -z "$token" ]] && continue
      is_include=false
      if [[ "$token" == *[\*\?\[]* ]] || _is_known_include "$token"; then
        is_include=true
      fi
      if [[ "${m:0:1}" == '+' ]]; then
        FORCE_INCLUDE+=("$token")
        INCLUDE_PATTERNS[$type]="$(_add_word "${INCLUDE_PATTERNS[$type]-}" "$token")"
        if ! $is_include; then
          EXCLUDE_DIRS[$type]="$(_add_word "${EXCLUDE_DIRS[$type]-}" "$token")"
        fi
      else
        if $is_include; then
          INCLUDE_PATTERNS[$type]="$(_remove_word "${INCLUDE_PATTERNS[$type]-}" "$token")"
        else
          EXCLUDE_DIRS[$type]="$(_remove_word "${EXCLUDE_DIRS[$type]-}" "$token")"
        fi
      fi
    done
  done
}

load_ctxrc() {
  local dir="$1" config_file="${CONFIG_FILE:-}"
  if [[ -z "$config_file" ]]; then
    [[ "$dir" != /* ]] && dir="$(cd "$dir" && pwd)"
    while [[ "$dir" != "/" ]]; do
      if [[ -f "$dir/.ktxrc" ]]; then config_file="$dir/.ktxrc"; break; fi
      if [[ -f "$dir/.ctxrc" ]]; then config_file="$dir/.ctxrc"; break; fi
      dir="$(dirname "$dir")"
    done
  fi
  [[ -n "$config_file" && -f "$config_file" ]] || return 0

  local section="global" section_type=""
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%%#*}"
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [[ -z "$line" ]] && continue
    if [[ "$line" =~ ^\[type:([a-zA-Z0-9_-]+)\]$ ]]; then
      section="type"
      section_type="${BASH_REMATCH[1]}"
      if [[ -z "${INCLUDE_PATTERNS[$section_type]+_}" ]]; then
        INCLUDE_PATTERNS[$section_type]="*"
        EXCLUDE_DIRS[$section_type]="$BASE_EXCLUDE_DIRS"
      fi
      continue
    fi
    if [[ "$section" == "type" ]]; then
      case "$line" in
        include=*) INCLUDE_PATTERNS[$section_type]="${line#include=}" ;;
        exclude=*) EXCLUDE_DIRS[$section_type]="$BASE_EXCLUDE_DIRS ${line#exclude=}" ;;
        with=*)    TYPE_WITH[$section_type]="${line#with=}" ;;
        *)         TYPE_FILES[$section_type]+="${line}"$'\n' ;;
      esac
    else
      case "$line" in
        type=*)               type_from_rc="${line#type=}" ;;
        limit=*|max-tokens=*) MAX_TOKENS="${line#*=}" ;;
        agent-header=*)       AGENT_HEADER="${line#agent-header=}" ;;
        +*|-*)                MODS_FROM_RC+=("$line") ;;
      esac
    fi
  done < "$config_file"
}

resolve_type_files() {
  local queue="$1" visited=" " t
  explicit_files=""
  while [[ -n "$queue" ]]; do
    t="${queue%%,*}"
    queue="${queue#"$t"}"
    queue="${queue#,}"
    t="${t#"${t%%[![:space:]]*}"}"
    t="${t%"${t##*[![:space:]]}"}"
    [[ -z "$t" || "$visited" == *" $t "* ]] && continue
    visited+="$t "
    [[ -n "${TYPE_FILES[$t]+_}" ]] && explicit_files+="${TYPE_FILES[$t]}"
    [[ -n "${TYPE_WITH[$t]+_}" ]] && queue+="${queue:+,}${TYPE_WITH[$t]}"
  done
}

show_stats() {
  (( ${#EXT_TOK[@]} == 0 )) && return
  local header="Tokens" max ext tok f tok_max
  max=${#header}
  for ext in "${!EXT_TOK[@]}"; do
    (( ${#ext} > max )) && max=${#ext}
  done
  (( max < 9 )) && max=9
  tok_max=${#header}
  for tok in "${EXT_TOK[@]}"; do
    f="$(fmt_num "$tok")"
    (( ${#f} > tok_max )) && tok_max=${#f}
  done
  printf '%-*s | Files | %*s\n' "$max" "Extension" "$tok_max" "$header" >&2
  printf '%s-|-------|-%s\n' \
    "$(printf '%*s' "$max" '' | tr ' ' '-')" \
    "$(printf '%*s' "$tok_max" '' | tr ' ' '-')" >&2
  for ext in "${!EXT_TOK[@]}"; do
    printf '%s\t%d\t%d\n' "$ext" "${EXT_CNT[$ext]}" "${EXT_TOK[$ext]}"
  done | sort -t$'\t' -k3,3nr |
  while IFS=$'\t' read -r ext cnt raw; do
    printf '%-*s | %5d | %*s\n' "$max" "$ext" "$cnt" "$tok_max" "$(fmt_num "$raw")" >&2
  done
}

is_globally_excluded() {
  local base="$1" pat
  for pat in "${FORCE_INCLUDE[@]}"; do
    case "$base" in $pat) return 1 ;; esac
  done
  for pat in "${GLOBAL_EXCLUDE_FILES[@]}"; do
    case "$base" in $pat) IGNORED_BY="$pat"; return 0 ;; esac
  done
  return 1
}

copy_to_clipboard() {
  local content="$1"
  if command -v pbcopy >/dev/null 2>&1; then
    printf '%s' "$content" | pbcopy
  elif command -v wl-copy >/dev/null 2>&1; then
    printf '%s' "$content" | wl-copy
  elif command -v xclip >/dev/null 2>&1; then
    printf '%s' "$content" | xclip -selection clipboard
  elif command -v xsel >/dev/null 2>&1; then
    printf '%s' "$content" | xsel --clipboard --input
  else
    return 1
  fi
}

run_tree() {
  local dir="$1" type="$2"
  printf '### Directory Tree\n'
  if command -v tree-git-ignore >/dev/null 2>&1; then
    tree-git-ignore -a --noreport --prune "$dir" || true
  elif command -v tree >/dev/null 2>&1; then
    local -a tree_opts=(-a --noreport --prune)
    local ignore_pat="${EXCLUDE_DIRS[$type]-}"
    ignore_pat="${ignore_pat// /|}"
    [[ -n "$ignore_pat" ]] && tree_opts+=(-I "${ignore_pat%|}")
    tree "${tree_opts[@]}" "$dir" || true
  else
    printf '(tree not found)\n'
  fi
  printf '\n'
}

run_files() {
  local dir="$1" files_input="$2" total_bytes=0 total_words=0
  while IFS= read -r f; do
    f="${f#"${f%%[![:space:]]*}"}"
    f="${f%"${f##*[![:space:]]}"}"
    [[ -z "$f" ]] && continue
    local fp
    if [[ "$f" == /* ]]; then fp="$f"; else fp="$dir/$f"; fi
    [[ -f "$fp" && -s "$fp" ]] || continue
    local fsize fwords
    read -r fwords fsize <<< "$(wc -wc < "$fp")"
    total_bytes=$((total_bytes + fsize))
    total_words=$((total_words + fwords))
    if (( MAX_TOKENS > 0 && (total_bytes * 100 / 680 + total_words * 65 / 100) > MAX_TOKENS )); then
      break
    fi
    local base="${fp##*/}" ext ftok
    ftok=$((fsize * 100 / 680 + fwords * 65 / 100))
    if [[ "$base" == .* ]]; then ext="$base"; else ext=".${base##*.}"; fi
    EXT_CNT[$ext]=$(( ${EXT_CNT[$ext]:-0} + 1 ))
    EXT_TOK[$ext]=$(( ${EXT_TOK[$ext]:-0} + ftok ))
    printf '### %s\n' "$f"
    tr -d '\0' < "$fp"
    printf '\n\n'
    FILE_COUNT=$((FILE_COUNT + 1))
  done <<< "$files_input"
}

build_find_args() {
  local dir="$1" type="$2"
  FIND_ARGS=("find" "$dir")

  if [[ -n "${EXCLUDE_DIRS[$type]-}" ]]; then
    FIND_ARGS+=('(')
    local first=1
    for d in ${EXCLUDE_DIRS[$type]}; do
      (( first )) || FIND_ARGS+=(-o)
      first=0
      FIND_ARGS+=(-type d -name "$d")
    done
    FIND_ARGS+=(')' -prune -o)
  fi

  FIND_ARGS+=(-type f)

  if [[ "${INCLUDE_PATTERNS[$type]}" != "*" ]]; then
    FIND_ARGS+=('(')
    local first=1
    for p in ${INCLUDE_PATTERNS[$type]}; do
      (( first )) || FIND_ARGS+=(-o)
      first=0
      FIND_ARGS+=(-name "$p")
    done
    FIND_ARGS+=(')')
  fi

  FIND_ARGS+=(-print0)
}

run_find() {
  local dir="$1" type="$2" total_bytes=0 total_words=0
  local -a FIND_ARGS=()
  build_find_args "$dir" "$type"

  while IFS= read -r -d '' file; do
    [[ ! -s "$file" ]] && continue
    local base="${file##*/}"
    if is_globally_excluded "$base"; then
      $SHOW_IGNORED && printf 'SKIP [%s]: %s\n' "$IGNORED_BY" "$file" >&2
      SKIP_COUNT=$((SKIP_COUNT + 1))
      continue
    fi
    local fsize fwords
    read -r fwords fsize <<< "$(wc -wc < "$file")"
    total_bytes=$((total_bytes + fsize))
    total_words=$((total_words + fwords))
    if (( MAX_TOKENS > 0 && (total_bytes * 100 / 680 + total_words * 65 / 100) > MAX_TOKENS )); then
      break
    fi
    local ext ftok
    ftok=$((fsize * 100 / 680 + fwords * 65 / 100))
    if [[ "$base" == .* ]]; then ext="$base"; else ext=".${base##*.}"; fi
    EXT_CNT[$ext]=$(( ${EXT_CNT[$ext]:-0} + 1 ))
    EXT_TOK[$ext]=$(( ${EXT_TOK[$ext]:-0} + ftok ))
    printf '### %s\n' "$file"
    tr -d '\0' < "$file"
    printf '\n\n'
    FILE_COUNT=$((FILE_COUNT + 1))
  done < <(
    if $RANDOM_ORDER && command -v shuf >/dev/null 2>&1; then
      "${FIND_ARGS[@]}" 2>/dev/null | shuf -z
    else
      "${FIND_ARGS[@]}" 2>/dev/null
    fi
  )
}

usage() {
cat >&2 <<EOF
ktx $VERSION
Usage: ktx [options] [modifiers...] [dir] [.type]

Options:
  -o FILE    Write to file (+ clipboard)
  -l N       Token budget (0=unlimited)
  -r         Randomize file order
  -T         Skip directory tree
  -I         Show skipped files on stderr
  -c FILE    Config file (default: .ktxrc upward)
  --raw      No header, no AGENTS.md
  -v         Version

Types: default js py go rs c java
Modifiers: +PAT,... / -PAT,...
EOF
}

main() {
  local out_file="" no_clip=false use_tree=true
  local type_explicit=false type_from_rc="" type_arg=""
  local -a MODS=() MODS_FROM_RC=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)                        usage; exit 0 ;;
      -v|--version)                     echo "ktx $VERSION"; exit 0 ;;
      -o|--output)                      out_file="$2"; shift 2 ;;
      -c|--config)                      CONFIG_FILE="$2"; shift 2 ;;
      --no-clip)                        no_clip=true; shift ;;
      -T|--no-tree)                     use_tree=false; shift ;;
      -m|-l|--limit|--max-tokens)       MAX_TOKENS="$2"; shift 2 ;;
      -r|--randomize)                   RANDOM_ORDER=true; shift ;;
      -I|--ignored)                     SHOW_IGNORED=true; shift ;;
      --raw)                            RAW_MODE=true; shift ;;
      +*|-*)                            MODS+=("$1"); shift ;;
      *)                                break ;;
    esac
  done

  local input="${1:-.}"
  [[ $# -gt 0 ]] && shift

  while [[ $# -gt 0 ]]; do
    case "$1" in
      +*|-*) MODS+=("$1") ;;
      .*)    type_arg="${1#.}"; type_explicit=true ;;
      *)     break ;;
    esac
    shift
  done

  local dir="$input" type="default"
  if [[ "$dir" == *.* && ! -d "$dir" ]]; then
    type="${dir##*.}"
    dir="${dir%.*}"
    [[ -z "$dir" ]] && dir="."
    type_explicit=true
  fi
  if [[ -n "$type_arg" ]]; then
    type="$type_arg"
    type_explicit=true
  fi
  [[ -d "$dir" ]] || { echo "Dir '$dir' not found" >&2; exit 1; }

  load_ctxrc "$dir"
  [[ -n "$type_from_rc" && "$type_explicit" == false ]] && type="$type_from_rc"
  (( ${#MODS_FROM_RC[@]} )) && apply_mods "$type" "${MODS_FROM_RC[@]}"
  (( ${#MODS[@]} )) && apply_mods "$type" "${MODS[@]}"

  local explicit_files=""
  resolve_type_files "$type"

  local tmp
  tmp="$(mktemp)"

  if ! $RAW_MODE; then
    printf '%s\n\n' "$AGENT_HEADER" >> "$tmp"
  fi
  printf '## Context for %s\n' "$(cd "$dir" && pwd)" >> "$tmp"

  if $use_tree; then
    run_tree "$dir" "$type" >> "$tmp"
  fi

  if ! $RAW_MODE && [[ -f "$dir/AGENTS.md" ]]; then
    printf '### System Prompt\n' >> "$tmp"
    cat "$dir/AGENTS.md" >> "$tmp"
    printf '\n\n' >> "$tmp"
  fi

  if [[ -n "${explicit_files//[[:space:]]/}" ]]; then
    run_files "$dir" "$explicit_files" >> "$tmp"
  else
    run_find "$dir" "$type" >> "$tmp"
  fi

  local content
  content="$(<"$tmp")"
  rm -f "$tmp"

  if [[ "$FILE_COUNT" -eq 0 ]]; then
    echo "No files found" >&2
    exit 0
  fi

  local -a dests=()
  if ! $no_clip && copy_to_clipboard "$content"; then
    dests+=(clipboard)
  fi
  if [[ -n "$out_file" ]]; then
    printf '%s' "$content" > "$out_file"
    dests+=("$out_file")
  fi
  [[ ${#dests[@]} -eq 0 ]] && dests+=(stdout)

  show_stats

  local total_tok total
  total_tok=$(( $(printf '%s' "$content" | wc -c) * 100 / 680 + $(printf '%s' "$content" | wc -w) * 65 / 100 ))
  total="$(fmt_num "$total_tok")"
  if (( SKIP_COUNT > 0 )); then
    echo "Context for '$dir' (type: $type) -> ${dests[*]} (~$total tokens, $SKIP_COUNT skipped)" >&2
  else
    echo "Context for '$dir' (type: $type) -> ${dests[*]} (~$total tokens)" >&2
  fi
  [[ "${dests[*]}" == *stdout* ]] && printf '%s' "$content"
}

main "$@"
