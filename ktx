#!/usr/bin/env bash
set -xeuo pipefail

VERSION="0.1.1"

# ── Type presets ────────────────────────────────────────────────────
declare -A EXCLUDE_DIRS=(
  [default]=''
  [js]='node_modules .next .nuxt .turbo bower_components dist build out coverage .nyc_output'
  [py]='__pycache__ .venv venv .mypy_cache .pytest_cache .ruff_cache .tox *.egg-info htmlcov dist build'
  [go]='vendor dist build'
  [rs]='target dist build'
  [c]='build .cache out'
  [java]='.gradle build target out'
)
declare -A INCLUDE_PATTERNS=(
  [default]='*'
  [js]='*.js *.ts *.jsx *.tsx *.mjs *.cjs *.json *.html *.css *.scss *.svelte *.vue *.md'
  [py]='*.py *.pyw *.pyi *.toml *.cfg *.ini *.json *.yml *.yaml *.md *.txt *.rst *.j2 Makefile Dockerfile'
  [go]='*.go *.mod *.sum *.json *.yml *.yaml *.md *.toml Makefile Dockerfile'
  [rs]='*.rs *.toml *.json *.yml *.yaml *.md Makefile Dockerfile'
  [c]='*.c *.h *.cpp *.hpp *.cc *.cxx *.hh *.inl *.cmake *.json *.yml *.yaml *.md Makefile CMakeLists.txt'
  [java]='*.java *.xml *.gradle *.properties *.yml *.yaml *.md'
)

# ── Base (always excluded dirs) ─────────────────────────────────────
BASE_EXCLUDE_DIRS='.git .svn .hg .idea .vscode .vs'

# ── Global file exclusions (secrets, binaries, noise) ───────────────
GLOBAL_EXCLUDE_FILES=(
  .DS_Store Thumbs.db desktop.ini .env '.env.*' .envrc
  '*.pem' '*.key' '*.p12' '*.pfx' '*.keystore' '*.jks'
  .npmrc .netrc .htpasswd 'id_rsa*' 'id_ed*'
  '*.secret' '*.credentials' '*.tfvars' '*.tfstate' '*.tfstate.*'
  '*.pyc' '*.pyo' '*.so' '*.dylib' '*.dll' '*.o' '*.a' '*.obj'
  '*.class' '*.jar' '*.exe' '*.bin'
  '*.png' '*.jpg' '*.jpeg' '*.gif' '*.ico' '*.svg' '*.webp' '*.bmp' '*.tiff'
  '*.woff' '*.woff2' '*.ttf' '*.eot' '*.otf'
  '*.mp3' '*.mp4' '*.wav' '*.avi' '*.mov' '*.webm' '*.pdf'
  '*.zip' '*.gz' '*.tgz' '*.rar' '*.7z' '*.bz2' '*.xz'
  '*.lock' package-lock.json pnpm-lock.yaml
  '*.min.js' '*.min.css' '*.map'
  '*.db' '*.sqlite' '*.sqlite3' '*.log' '*.pid' '*.out'
  LICENSE LICENSE.md LICENSE.txt LICENCE LICENCE.md
  CHANGELOG CHANGELOG.md compile_commands.json AGENTS.md .ktxrc .ctxrc
)

# Merge base into every type
for _k in "${!INCLUDE_PATTERNS[@]}"; do
  EXCLUDE_DIRS[$_k]="$BASE_EXCLUDE_DIRS ${EXCLUDE_DIRS[$_k]-}"
done; unset _k

declare -A EXT_CNT=() EXT_TOK=()
declare -A TYPE_FILES=()
declare -A TYPE_WITH=()
declare -a FORCE_INCLUDE=()
MAX_TOKENS=0
SHOW_IGNORED=false
RANDOM_ORDER=false
RAW_MODE=false
AGENT_HEADER="Please state the full filename with its extension in the line immediately preceding each code block!"
IGNORED_BY=''
SKIP_COUNT=0
FILE_COUNT=0

tok_est() {
  local b w
  [[ -f "$1" ]] || { echo 0; return; }
  b=$(wc -c <"$1")
  w=$(wc -w <"$1")
  echo $(( b*100/680 + w*65/100 ))
}

tok_est_str() {
  echo $(( ${1:-0}*100/680 + ${2:-0}*65/100 ))
}

fmt_num() {
  case "$1" in
    ''|*[!0-9]*) printf '%s' "$1";;
    *) if command -v numfmt >/dev/null 2>&1; then LC_NUMERIC=C numfmt --grouping "$1" 2>/dev/null || printf '%s' "$1"; else printf '%s' "$1"; fi;;
  esac
}

_add_word() {
  local cur="$1" token="$2" w
  for w in $cur; do [[ "$w" == "$token" ]] && { printf '%s' "$cur"; return; }; done
  printf '%s %s' "$cur" "$token"
}

_remove_word() {
  local cur="$1" token="$2" out= w
  for w in $cur; do [[ "$w" == "$token" ]] || out="$out $w"; done
  echo "${out#"${out%%[! ]*}"}"
}

apply_mods() {
  local type="$1"; shift
  local m body part token target
  for m in "$@"; do
    body=${m:1}
    IFS=',' read -r -a parts <<<"$body"
    for part in "${parts[@]}"; do
      token="${part#"${part%%[![:space:]]*}"}"
      token="${token%"${token##*[![:space:]]}"}"
      [[ -z $token ]] && continue
      target=$([[ $token == *[\*\?\[]* || $token == Makefile || $token == Dockerfile ]] && echo "include" || echo "exclude")
      if [[ ${m:0:1} == '+' ]]; then
        FORCE_INCLUDE+=("$token")
        INCLUDE_PATTERNS["$type"]=$(_add_word "${INCLUDE_PATTERNS[$type]-}" "$token")
        [[ $target == exclude ]] && EXCLUDE_DIRS["$type"]=$(_add_word "${EXCLUDE_DIRS[$type]-}" "$token")
      else
        if [[ $target == include ]]; then INCLUDE_PATTERNS["$type"]=$(_remove_word "${INCLUDE_PATTERNS[$type]-}" "$token")
        else EXCLUDE_DIRS["$type"]=$(_remove_word "${EXCLUDE_DIRS[$type]-}" "$token"); fi
      fi
    done
  done
}

load_ctxrc() {
  local dir="$1" config_file=""
  while [[ "$dir" != "/" && "$dir" != "." ]]; do
    if [[ -f "$dir/.ktxrc" ]]; then config_file="$dir/.ktxrc"; break; fi
    if [[ -f "$dir/.ctxrc" ]]; then config_file="$dir/.ctxrc"; break; fi
    dir=$(dirname "$dir")
  done
  [[ -f "$config_file" ]] || return 0

  local section="global" section_type=""
  while IFS= read -r line || [[ -n $line ]]; do
    line="${line%%#*}"
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [[ -z $line ]] && continue
    if [[ $line =~ ^\[type:([a-zA-Z0-9_-]+)\]$ ]]; then
      section="type"; section_type="${BASH_REMATCH[1]}"
      if [[ -z "${INCLUDE_PATTERNS[$section_type]+_}" ]]; then
        INCLUDE_PATTERNS[$section_type]="*"; EXCLUDE_DIRS[$section_type]="$BASE_EXCLUDE_DIRS"
      fi
      continue
    fi
    if [[ $section == "type" ]]; then
      case "$line" in
        include=*) INCLUDE_PATTERNS[$section_type]="${line#include=}" ;;
        exclude=*) EXCLUDE_DIRS[$section_type]="$BASE_EXCLUDE_DIRS ${line#exclude=}" ;;
        with=*)    TYPE_WITH[$section_type]="${line#with=}" ;;
        *)         TYPE_FILES[$section_type]+="$line"$'\n' ;;
      esac
    else
      case "$line" in
        type=*)          type_from_rc="${line#type=}" ;;
        limit=*|max-tokens=*) MAX_TOKENS="${line#*=}" ;;
        agent-header=*)  AGENT_HEADER="${line#agent-header=}" ;;
        +*|-*)           MODS_FROM_RC+=("$line") ;;
      esac
    fi
  done < "$config_file"
}

resolve_type_files() {
  local queue="$1" visited=" " t
  explicit_files=""
  while [[ -n "$queue" ]]; do
    t="${queue%%,*}"; queue="${queue#"$t"}"; queue="${queue#,}"
    t="${t#"${t%%[![:space:]]*}"}"; t="${t%"${t##*[![:space:]]}"}"
    [[ -z "$t" || "$visited" == *" $t "* ]] && continue
    visited+="$t "
    [[ -n "${TYPE_FILES[$t]+_}" ]] && explicit_files+="${TYPE_FILES[$t]}"
    [[ -n "${TYPE_WITH[$t]+_}" ]] && queue+="${queue:+,}${TYPE_WITH[$t]}"
  done
}

show_stats() {
  (( ${#EXT_TOK[@]} == 0 )) && return
  local header="Tokens" max ext tok f tok_max
  max=${#header}
  for ext in "${!EXT_TOK[@]}"; do (( ${#ext} > max )) && max=${#ext}; done
  (( max < 9 )) && max=9
  tok_max=${#header}
  for tok in "${EXT_TOK[@]}"; do f=$(fmt_num "$tok"); (( ${#f} > tok_max )) && tok_max=${#f}; done
  printf '%-*s | Files | %*s\n' "$max" "Extension" "$tok_max" "$header" >&2
  printf '%s-|-------|-%s\n' "$(printf '%*s' "$max" '' | tr ' ' '-')" "$(printf '%*s' "$tok_max" '' | tr ' ' '-')" >&2
  for ext in "${!EXT_TOK[@]}"; do printf '%s\t%d\t%d\n' "$ext" "${EXT_CNT["$ext"]}" "${EXT_TOK["$ext"]}"; done | sort -t$'\t' -k3,3nr |
  while IFS=$'\t' read -r ext cnt raw; do
    printf '%-*s | %5d | %*s\n' "$max" "$ext" "$cnt" "$tok_max" "$(fmt_num "$raw")" >&2
  done
}

is_globally_excluded() {
  local base="$1" pat
  for pat in "${FORCE_INCLUDE[@]}"; do case "$base" in $pat) return 1 ;; esac; done
  for pat in "${GLOBAL_EXCLUDE_FILES[@]}"; do case "$base" in $pat) IGNORED_BY="$pat"; return 0 ;; esac; done
  return 1
}

copy_to_clipboard() {
  local content="$1"
  if   command -v pbcopy  >/dev/null 2>&1; then printf '%s' "$content" | pbcopy
  elif command -v wl-copy >/dev/null 2>&1; then printf '%s' "$content" | wl-copy
  elif command -v xclip   >/dev/null 2>&1; then printf '%s' "$content" | xclip -selection clipboard
  elif command -v xsel    >/dev/null 2>&1; then printf '%s' "$content" | xsel --clipboard --input
  else return 1; fi
}

run_tree() {
  local dir=$1 type=$2
  printf '### Directory Tree\n'
  if command -v tree-git-ignore >/dev/null 2>&1; then tree-git-ignore -a --noreport --prune "$dir" || true
  elif command -v tree >/dev/null 2>&1; then
    local tree_opts=(-a --noreport --prune)
    local ignore_pat="${EXCLUDE_DIRS[$type]-}"; ignore_pat="${ignore_pat// /|}"
    [[ -n "$ignore_pat" ]] && tree_opts+=(-I "${ignore_pat%|}")
    tree "${tree_opts[@]}" "$dir" || true
  else printf '(tree not found)\n'; fi
  printf '\n'
}

run_files() {
  local dir=$1 files_input="$2" total_bytes=0 total_words=0
  while IFS= read -r f; do
    f="${f#"${f%%[![:space:]]*}"}"; f="${f%"${f##*[![:space:]]}"}"
    [[ -z "$f" ]] && continue
    local fp; [[ $f == /* ]] && fp="$f" || fp="$dir/$f"
    [[ -f "$fp" && -s "$fp" ]] || continue
    local fsize=$(wc -c <"$fp") fwords=$(wc -w <"$fp")
    total_bytes=$((total_bytes + fsize)); total_words=$((total_words + fwords))
    if (( MAX_TOKENS > 0 && $(tok_est_str "$total_bytes" "$total_words") > MAX_TOKENS )); then break; fi
    local base="${fp##*/}" ext; [[ $base == .* ]] && ext="$base" || ext=".${base##*.}"
    EXT_CNT[$ext]=$(( ${EXT_CNT[$ext]:-0} + 1 )); EXT_TOK[$ext]=$(( ${EXT_TOK[$ext]:-0} + $(tok_est "$fp") ))
    printf '### %s\n' "$f"; tr -d '\0' <"$fp"; printf '\n\n'; ((FILE_COUNT++))
  done <<< "$files_input"
}

run_find() {
  local dir=$1 type=$2 total_bytes=0 total_words=0
  local -a args=("find" "$dir")
  [[ -n "${EXCLUDE_DIRS[$type]-}" ]] && {
    args+=(\(); local first=1; for d in ${EXCLUDE_DIRS[$type]}; do (( first )) || args+=(-o); first=0; args+=(-type d -name "$d"); done; args+=(\) -prune -o)
  }
  args+=(-type f); [[ "${INCLUDE_PATTERNS[$type]}" != "*" ]] && {
    args+=(\()); local first=1; for p in ${INCLUDE_PATTERNS[$type]}; do (( first )) || args+=(-o); first=0; args+=(-name "$p"); done; args+=(\))
  }
  args+=(-print0)
  while IFS= read -r -d '' file; do
    [[ ! -s "$file" ]] && continue
    local base="${file##*/}"
    if is_globally_excluded "$base"; then ((SKIP_COUNT++)); continue; fi
    local fsize=$(wc -c <"$file") fwords=$(wc -w <"$file")
    total_bytes=$((total_bytes + fsize)); total_words=$((total_words + fwords))
    if (( MAX_TOKENS > 0 && $(tok_est_str "$total_bytes" "$total_words") > MAX_TOKENS )); then break; fi
    local ext; [[ $base == .* ]] && ext="$base" || ext=".${base##*.}"
    EXT_CNT[$ext]=$(( ${EXT_CNT[$ext]:-0} + 1 )); EXT_TOK[$ext]=$(( ${EXT_TOK[$ext]:-0} + $(tok_est "$file") ))
    printf '### %s\n' "$file"; tr -d '\0' <"$file"; printf '\n\n'; ((FILE_COUNT++))
  done < <("${args[@]}" 2>/dev/null)
}

main() {
  local out_file='' no_clip=false use_tree=true type_explicit=false type_from_rc='' type_arg=''
  local -a MODS=() MODS_FROM_RC=()
  while [[ $# -gt 0 ]]; do
    case $1 in
      -h|--help) echo "ktx $VERSION — Usage: ktx [options] [modifiers...] [dir] [.type]"; exit 0 ;;
      -o|--output) out_file=$2; shift 2 ;;
      --no-clip) no_clip=true; shift ;;
      -T|--no-tree) use_tree=false; shift ;;
      -m|-l|--limit|--max-tokens) MAX_TOKENS=$2; shift 2 ;;
      -r|--randomize) RANDOM_ORDER=true; shift ;;
      -I|--ignored) SHOW_IGNORED=true; shift ;;
      --raw) RAW_MODE=true; shift ;;
      +*|-*) MODS+=("$1"); shift ;;
      *) break ;;
    esac
  done

  local input="${1:-.}"
  [[ $# -gt 0 ]] && shift
  while [[ $# -gt 0 ]]; do
    case "$1" in
      +*|-*) MODS+=("$1") ;;
      .*) type_arg="${1#.}" ; type_explicit=true ;;
      *) break ;;
    esac
    shift
  done

  local dir="$input" type="default"
  if [[ $dir == *.* && ! -d $dir ]]; then type="${dir##*.}"; dir="${dir%.*}"; type_explicit=true; fi
  [[ -n "$type_arg" ]] && { type="$type_arg"; type_explicit=true; }
  [[ -d "$dir" ]] || { echo "Dir '$dir' not found" >&2; exit 1; }

  load_ctxrc "$dir"
  [[ -n $type_from_rc && $type_explicit == false ]] && type="$type_from_rc"
  (( ${#MODS_FROM_RC[@]} )) && apply_mods "$type" "${MODS_FROM_RC[@]}"
  (( ${#MODS[@]} ))         && apply_mods "$type" "${MODS[@]}"

  local explicit_files=""; resolve_type_files "$type"
  local tmp=$(mktemp)
  if ! $RAW_MODE; then printf '%s\n\n' "$AGENT_HEADER" >> "$tmp"; fi
  printf '## Context for %s\n' "$(cd "$dir" && pwd)" >> "$tmp"
  $use_tree && run_tree "$dir" "$type" >> "$tmp"
  if ! $RAW_MODE && [[ -f "$dir/AGENTS.md" ]]; then printf '### System Prompt\n' >> "$tmp"; cat "$dir/AGENTS.md" >> "$tmp"; printf '\n\n' >> "$tmp"; fi

  if [[ -n "${explicit_files//[[:space:]]/}" ]]; then run_files "$dir" "$explicit_files" >> "$tmp"
  else run_find "$dir" "$type" >> "$tmp"; fi

  local content=$(<"$tmp"); rm -f "$tmp"
  if [[ $FILE_COUNT -eq 0 ]]; then echo "No files found" >&2; exit 0; fi

  local dests=()
  if ! $no_clip && copy_to_clipboard "$content"; then dests+=(clipboard); fi
  if [[ -n "$out_file" ]]; then printf '%s' "$content" >"$out_file"; dests+=("$out_file"); fi
  [[ ${#dests[@]} -eq 0 ]] && dests+=(stdout)

  show_stats
  local total=$(fmt_num "$(( $(printf '%s' "$content" | wc -c)*100/680 + $(printf '%s' "$content" | wc -w)*65/100 ))")
  echo "Context for '$dir' (type: $type) → ${dests[*]} (~$total tokens)" >&2
  [[ ${dests[*]} == *stdout* ]] && printf '%s' "$content"
}

main "$@"
