#!/usr/bin/env bash
set -euo pipefail

VERSION="0.2.4"

# ── Always-excluded directories (never traversed) ─────────────────
ALWAYS_EXCLUDE_DIRS='.git .svn .hg .idea .vscode .vs'

# ── Language presets ───────────────────────────────────────────────
declare -A EXCLUDE_DIRS=(
  [default]=''
  [js]='node_modules .next .nuxt .turbo bower_components dist build out coverage .nyc_output'
  [py]='__pycache__ .venv venv .mypy_cache .pytest_cache .ruff_cache .tox *.egg-info htmlcov dist build'
)
declare -A INCLUDE_PATTERNS=(
  [default]='*'
  [js]='*.js *.ts *.jsx *.tsx *.mjs *.cjs *.json *.html *.css *.scss *.svelte *.vue *.md'
  [py]='*.py *.pyw *.pyi *.toml *.cfg *.ini *.json *.yml *.yaml *.md *.txt *.rst *.j2 Makefile Dockerfile'
)

# ── Global file blocklist ─────────────────────────────────────────
GLOBAL_EXCLUDE_FILES='\
.DS_Store Thumbs.db desktop.ini \
.env .env.* .envrc *.pem *.key *.p12 *.pfx .npmrc .netrc id_rsa* id_ed* *.secret *.credentials *.tfvars *.tfstate \
*.pyc *.pyo *.so *.dylib *.dll *.o *.a *.obj *.class *.jar *.exe *.bin \
*.png *.jpg *.jpeg *.gif *.ico *.svg *.webp *.bmp *.tiff *.woff *.woff2 *.ttf *.eot *.otf *.mp3 *.mp4 *.wav *.avi *.mov *.webm *.pdf \
*.zip *.gz *.tgz *.rar *.7z *.bz2 *.xz \
*.lock package-lock.json pnpm-lock.yaml *.min.js *.min.css *.map \
*.db *.sqlite *.sqlite3 *.log *.pid *.out \
LICENSE CHANGELOG compile_commands.json AGENTS.md .ktxrc .ctxrc'

declare -a _GBL_EXCL=()
_build_gbl_excl() { set -f; local p; for p in $GLOBAL_EXCLUDE_FILES; do _GBL_EXCL+=("$p"); done; set +f; }
_build_gbl_excl

# ── Runtime state ──────────────────────────────────────────────────
declare -a FORCE_INCLUDE=()
declare -a RC_MODS=()
declare -A EXT_CNT=() EXT_TOK=()
declare -A CUSTOM_TYPE_INCLUDE=()
declare -A CUSTOM_TYPE_EXCLUDE=()
declare -A CUSTOM_TYPE_FILES=()
declare -A CUSTOM_TYPE_WITH=()
declare -A CUSTOM_TYPES=()

MAX_TOKENS=0
RANDOM_ORDER=false
SHOW_IGNORED=false
RAW_MODE=false
USE_TREE=true
OUT_FILE=''
OUT_TO_FILE=false
CONFIG_FILE=''
DEFAULT_HEADER='Please state the full filename with its extension in the line immediately preceding each code block!'
AGENT_HEADER="$DEFAULT_HEADER"
AGENT_HEADER_SET=false
FILE_COUNT=0
SKIP_COUNT=0
RC_DIR=''
_TYPE_FROM_RC=''

# ── Token estimation ──────────────────────────────────────────────
tok_est_file() {
  local b w
  b=$(($(wc -c < "$1")))
  w=$(($(wc -w < "$1")))
  echo $(( b * 100 / 680 + w * 65 / 100 ))
}

tok_est_nums() {
  echo $(( ${1:-0} * 100 / 680 + ${2:-0} * 65 / 100 ))
}

fmt_num() {
  case "$1" in
    ''|*[!0-9]*) printf '%s' "$1" ;;
    *)
      if command -v numfmt >/dev/null 2>&1; then
        LC_NUMERIC=C numfmt --grouping "$1" 2>/dev/null || printf '%s' "$1"
      else
        printf '%s' "$1"
      fi ;;
  esac
}

# ── Word-list helpers ──────────────────────────────────────────────
_add_word() {
  set -f
  local cur="$1" token="$2" w
  for w in $cur; do
    if [[ "$w" == "$token" ]]; then
      printf '%s' "$cur"
      set +f
      return
    fi
  done
  if [[ -n "$cur" ]]; then
    printf '%s %s' "$cur" "$token"
  else
    printf '%s' "$token"
  fi
  set +f
}

_remove_word() {
  set -f
  local cur="$1" token="$2" out="" w
  for w in $cur; do
    if [[ "$w" != "$token" ]]; then
      out="$out $w"
    fi
  done
  printf '%s' "${out#"${out%%[! ]*}"}"
  set +f
}

_is_known_include() {
  local token=$1 t p
  for t in "${!INCLUDE_PATTERNS[@]}"; do
    set -f
    for p in ${INCLUDE_PATTERNS[$t]}; do
      if [[ "$p" == "$token" ]]; then set +f; return 0; fi
    done
    set +f
  done
  for t in "${!CUSTOM_TYPE_INCLUDE[@]}"; do
    set -f
    for p in ${CUSTOM_TYPE_INCLUDE[$t]}; do
      if [[ "$p" == "$token" ]]; then set +f; return 0; fi
    done
    set +f
  done
  return 1
}

_is_glob() {
  [[ $1 == *[\*\?\[]* ]]
}

# ── Extension detection ───────────────────────────────────────────
_file_ext() {
  local base=$1
  if [[ $base == .*.* ]]; then
    _ext="$base"
  elif [[ $base == *.* ]]; then
    _ext=".${base##*.}"
  else
    _ext="$base"
  fi
}

# ── Modifier application ──────────────────────────────────────────
apply_mods() {
  local type="$1"; shift
  local m body part token is_glob is_known
  for m in "$@"; do
    body=${m:1}
    IFS=',' read -r -a parts <<< "$body"
    for part in "${parts[@]}"; do
      token="${part#"${part%%[![:space:]]*}"}"
      token="${token%"${token##*[![:space:]]}"}"
      [[ -z $token ]] && continue

      is_glob=false; is_known=false
      if _is_glob "$token"; then is_glob=true; fi
      if _is_known_include "$token"; then is_known=true; fi

      if [[ ${m:0:1} == '+' ]]; then
        FORCE_INCLUDE+=("$token")
        INCLUDE_PATTERNS["$type"]=$(_add_word "${INCLUDE_PATTERNS[$type]-}" "$token")
      else
        if $is_glob || $is_known; then
          INCLUDE_PATTERNS["$type"]=$(_remove_word "${INCLUDE_PATTERNS[$type]-}" "$token")
        else
          EXCLUDE_DIRS["$type"]=$(_remove_word "${EXCLUDE_DIRS[$type]-}" "$token")
        fi
      fi
    done
  done
}

# ── Config discovery & loading ─────────────────────────────────────
find_ktxrc() {
  local dir
  dir=$(cd "$1" >/dev/null 2>&1 && pwd)
  while true; do
    [[ -f "$dir/.ktxrc" ]] && { echo "$dir/.ktxrc"; return 0; }
    [[ -f "$dir/.ctxrc" ]] && { echo "$dir/.ctxrc"; return 0; }
    [[ "$dir" == "/" ]] && break
    dir=$(dirname "$dir")
  done
  return 1
}

load_ktxrc() {
  local file=$1 current_section=""
  [[ -f $file ]] || return 0
  RC_DIR=$(cd "$(dirname "$file")" >/dev/null 2>&1 && pwd)

  while IFS= read -r line || [[ -n $line ]]; do
    line="${line%$'\r'}"
    line=${line%%#*}
    line=${line#"${line%%[![:space:]]*}"}
    line=${line%"${line##*[![:space:]]}"}
    [[ -z $line ]] && continue

    if [[ $line =~ ^\[type:([a-zA-Z0-9_-]+)\]$ ]]; then
      current_section="${BASH_REMATCH[1]}"
      CUSTOM_TYPES["$current_section"]=1
      continue
    fi

    if [[ -n $current_section ]]; then
      case "$line" in
        include=*) CUSTOM_TYPE_INCLUDE["$current_section"]="${line#include=}" ;;
        exclude=*) CUSTOM_TYPE_EXCLUDE["$current_section"]="${line#exclude=}" ;;
        with=*)    CUSTOM_TYPE_WITH["$current_section"]="${line#with=}" ;;
        *)
          if [[ -n "${CUSTOM_TYPE_FILES[$current_section]+_}" ]]; then
            CUSTOM_TYPE_FILES["$current_section"]+=$'\n'"$line"
          else
            CUSTOM_TYPE_FILES["$current_section"]="$line"
          fi
          ;;
      esac
    else
      case "$line" in
        type=*)         _TYPE_FROM_RC="${line#type=}" ;;
        limit=*)        MAX_TOKENS="${line#limit=}" ;;
        agent-header=*) AGENT_HEADER="${line#agent-header=}"; AGENT_HEADER_SET=true ;;
        +*|-*)          RC_MODS+=("$line") ;;
      esac
    fi
  done < "$file"

  # FIX: use if/then instead of [[ ]] && to avoid a trailing exit-status
  # of 1 that kills the caller under set -e when the last custom type
  # processed has no exclude= directive.
  local ct
  for ct in "${!CUSTOM_TYPES[@]}"; do
    if [[ -n "${CUSTOM_TYPE_FILES[$ct]+_}" ]]; then
      : "${INCLUDE_PATTERNS[$ct]:=__filelist__}"
    else
      : "${INCLUDE_PATTERNS[$ct]:=}"
      if [[ -n "${CUSTOM_TYPE_INCLUDE[$ct]-}" ]]; then
        INCLUDE_PATTERNS["$ct"]="${CUSTOM_TYPE_INCLUDE[$ct]}"
      fi
      if [[ -n "${CUSTOM_TYPE_EXCLUDE[$ct]-}" ]]; then
        EXCLUDE_DIRS["$ct"]="${CUSTOM_TYPE_EXCLUDE[$ct]}"
      fi
    fi
  done
  return 0
}

# ── Resolve with= dependencies (cycle-safe BFS) ───────────────────
resolve_with() {
  local type=$1
  local -a order=() queue=("$type")
  local -A visited=()
  while (( ${#queue[@]} > 0 )); do
    local cur="${queue[0]}"
    if (( ${#queue[@]} > 1 )); then queue=("${queue[@]:1}"); else queue=(); fi
    if [[ -n "${visited[$cur]+_}" ]]; then continue; fi
    visited["$cur"]=1
    order+=("$cur")
    local wv="${CUSTOM_TYPE_WITH[$cur]-}"
    if [[ -n "$wv" ]]; then
      local dep
      IFS=',' read -r -a _deps <<< "$wv"
      for dep in "${_deps[@]}"; do
        dep="${dep#"${dep%%[![:space:]]*}"}"
        dep="${dep%"${dep##*[![:space:]]}"}"
        if [[ -n "$dep" ]]; then queue+=("$dep"); fi
      done
    fi
  done
  local i
  for (( i=${#order[@]}-1; i>=0; i-- )); do
    printf '%s\n' "${order[$i]}"
  done
}

# ── Merge include/exclude across with= DAG for pattern types ──────
_merge_pattern_type() {
  local type=$1
  local -a all_types
  mapfile -t all_types < <(resolve_with "$type")

  local merged_include="" merged_exclude="" t w
  for t in "${all_types[@]}"; do
    local inc="${INCLUDE_PATTERNS[$t]-}"
    if [[ -n "$inc" && "$inc" != "__filelist__" ]]; then
      set -f
      for w in $inc; do
        merged_include=$(_add_word "$merged_include" "$w")
      done
      set +f
    fi
    local exc="${EXCLUDE_DIRS[$t]-}"
    if [[ -n "$exc" ]]; then
      set -f
      for w in $exc; do
        merged_exclude=$(_add_word "$merged_exclude" "$w")
      done
      set +f
    fi
  done

  INCLUDE_PATTERNS["$type"]="$merged_include"
  EXCLUDE_DIRS["$type"]="$merged_exclude"
}

# ── Statistics ─────────────────────────────────────────────────────
show_stats() {
  if (( ${#EXT_TOK[@]} == 0 )); then return; fi

  local ext tok f
  local w_ext=9
  local w_tok=6

  for ext in "${!EXT_TOK[@]}"; do
    (( ${#ext} > w_ext )) && w_ext=${#ext}
  done
  for tok in "${EXT_TOK[@]}"; do
    f=$(fmt_num "$tok")
    (( ${#f} > w_tok )) && w_tok=${#f}
  done

  printf '%-*s | Files | %*s\n' "$w_ext" "Extension" "$w_tok" "Tokens" >&2

  local sep_ext="" sep_tok="" i
  for ((i=0; i<w_ext; i++)); do sep_ext+="-"; done
  for ((i=0; i<w_tok; i++)); do sep_tok+="-"; done
  printf '%s-|-------|-%s\n' "$sep_ext" "$sep_tok" >&2

  for ext in "${!EXT_TOK[@]}"; do
    printf '%s\t%d\t%d\n' "$ext" "${EXT_CNT[$ext]}" "${EXT_TOK[$ext]}"
  done | sort -t$'\t' -k3,3nr |
  while IFS=$'\t' read -r ext cnt raw; do
    printf '%-*s | %5d | %*s\n' "$w_ext" "$ext" "$cnt" "$w_tok" "$(fmt_num "$raw")" >&2
  done
}

# ── File exclusion check ──────────────────────────────────────────
is_globally_excluded() {
  local base="$1" pat
  if (( ${#FORCE_INCLUDE[@]} > 0 )); then
    for pat in "${FORCE_INCLUDE[@]}"; do
      case "$base" in $pat) return 1 ;; esac
    done
  fi
  for pat in "${_GBL_EXCL[@]}"; do
    case "$base" in $pat) return 0 ;; esac
  done
  return 1
}

# ── Clipboard ──────────────────────────────────────────────────────
copy_to_clipboard() {
  local content="$1"
  if   command -v pbcopy >/dev/null 2>&1; then printf '%s' "$content" | pbcopy
  elif command -v wl-copy >/dev/null 2>&1; then printf '%s' "$content" | wl-copy
  elif command -v xclip  >/dev/null 2>&1; then printf '%s' "$content" | xclip -selection clipboard
  elif command -v xsel   >/dev/null 2>&1; then printf '%s' "$content" | xsel --clipboard --input
  elif command -v clip   >/dev/null 2>&1; then printf '%s' "$content" | clip
  else return 1; fi
}

# ── Git integration ───────────────────────────────────────────────
get_git_ignored() {
  git -C "$1" ls-files -oi --exclude-standard --directory 2>/dev/null | sed 's~/$~~' || true
}

# ── Tree output ───────────────────────────────────────────────────
run_tree() {
  local dir=$1 type=$2

  printf '### Directory Tree\n'

  if command -v tree-git-ignore >/dev/null 2>&1; then
    tree-git-ignore -a --noreport --prune "$dir" || true
    printf '\n'
    return
  fi

  if ! command -v tree >/dev/null 2>&1; then
    printf '(Warning: "tree" not found, skipping tree view)\n\n'
    return
  fi

  local -a tree_opts=(-a --noreport --prune)
  local ignore_pat=""

  local all_excludes="$ALWAYS_EXCLUDE_DIRS"
  [[ -n "${EXCLUDE_DIRS[$type]-}" ]] && all_excludes+=" ${EXCLUDE_DIRS[$type]}"
  ignore_pat="${all_excludes// /|}"

  if git -C "$dir" rev-parse --is-inside-work-tree &>/dev/null; then
    local gi
    gi=$(get_git_ignored "$dir")
    if [[ -n "$gi" ]]; then
      local gp
      gp=$(echo "$gi" | tr '\n' '|')
      gp=${gp%|}
      if [[ -n "$ignore_pat" ]]; then ignore_pat+="|$gp"; else ignore_pat="$gp"; fi
    fi
  fi

  ignore_pat=${ignore_pat%|}
  if [[ -n "$ignore_pat" ]]; then tree_opts+=(-I "$ignore_pat"); fi

  tree "${tree_opts[@]}" "$dir" || true
  printf '\n'
}

# ── Pattern-based file discovery ───────────────────────────────────
run_find() {
  local dir=$1 type=$2
  local -a find_args=("$dir")

  local git_ignored=""
  declare -A GIT_IGNORED_MAP=()
  if git -C "$dir" rev-parse --is-inside-work-tree &>/dev/null; then
    git_ignored=$(get_git_ignored "$dir")
    if [[ -n "$git_ignored" ]]; then
      local g
      while IFS= read -r g; do
        if [[ -n "$g" ]]; then GIT_IGNORED_MAP["$g"]=1; fi
      done <<< "$git_ignored"
    fi
  fi

  local all_exclude_dirs="$ALWAYS_EXCLUDE_DIRS"
  if [[ -n "${EXCLUDE_DIRS[$type]-}" ]]; then
    all_exclude_dirs+=" ${EXCLUDE_DIRS[$type]}"
  fi

  set -f
  if [[ -n "$all_exclude_dirs" ]]; then
    find_args+=(\()
    local first=1 d
    for d in $all_exclude_dirs; do
      (( first )) || find_args+=(-o)
      first=0
      find_args+=(-name "$d")
    done
    find_args+=(\) -type d -prune -o)
  fi

  find_args+=(-type f)
  local inc_pats="${INCLUDE_PATTERNS[$type]-*}"
  if [[ "$inc_pats" != "*" ]]; then
    find_args+=(\()
    local first=1 pat
    for pat in $inc_pats; do
      (( first )) || find_args+=(-o)
      first=0
      find_args+=(-name "$pat")
    done
    find_args+=(\))
  fi
  set +f

  find_args+=(-print0)

  local tmpfile
  tmpfile=$(mktemp)
  if $RANDOM_ORDER && command -v shuf >/dev/null 2>&1; then
    find "${find_args[@]}" 2>/dev/null | shuf -z > "$tmpfile" || true
  else
    find "${find_args[@]}" 2>/dev/null > "$tmpfile" || true
  fi

  local total_bytes=0 total_words=0

  while IFS= read -r -d '' file; do
    [[ ! -f "$file" ]] && continue
    local base=${file##*/}

    if is_globally_excluded "$base"; then
      SKIP_COUNT=$((SKIP_COUNT + 1))
      if $SHOW_IGNORED; then printf 'SKIP [global]: %s\n' "$file" >&2; fi
      continue
    fi

    if [[ -n "$git_ignored" ]]; then
      local rel="${file#"$dir/"}"
      if [[ -n "${GIT_IGNORED_MAP["$rel"]+_}" ]]; then
        SKIP_COUNT=$((SKIP_COUNT + 1))
        if $SHOW_IGNORED; then printf 'SKIP [gitignore]: %s\n' "$file" >&2; fi
        continue
      fi
    fi

    local fsize fwords
    fsize=$(($(wc -c < "$file")))
    fwords=$(($(wc -w < "$file")))
    total_bytes=$((total_bytes + fsize))
    total_words=$((total_words + fwords))

    if [[ $MAX_TOKENS -gt 0 ]]; then
      local running
      running=$(tok_est_nums "$total_bytes" "$total_words")
      if (( running > MAX_TOKENS )); then
        printf '\n--- TOKEN BUDGET REACHED (%s tokens) ---\n' "$(fmt_num "$MAX_TOKENS")" >&2
        break
      fi
    fi

    local ext toks
    _file_ext "$base"; ext=$_ext
    toks=$(( fsize * 100 / 680 + fwords * 65 / 100 ))
    EXT_CNT[$ext]=$(( ${EXT_CNT[$ext]:-0} + 1 ))
    EXT_TOK[$ext]=$(( ${EXT_TOK[$ext]:-0} + toks ))
    FILE_COUNT=$((FILE_COUNT + 1))

    local -a hdr_lines
    mapfile -n2 -t hdr_lines < "$file" 2>/dev/null || true
    if [[ ${hdr_lines[0]:-} != *"$file"* && ${hdr_lines[1]:-} != *"$file"* \
       && ${hdr_lines[0]:-} != *"$base"* && ${hdr_lines[1]:-} != *"$base"* ]]; then
      printf '### %s\n' "$file"
    fi
    tr -d '\0' < "$file"; printf '\n\n'
  done < "$tmpfile"

  rm -f "$tmpfile"
}

# ── File-list mode ─────────────────────────────────────────────────
run_files() {
  local dir=$1 type=$2
  local total_bytes=0 total_words=0
  local files_base="${RC_DIR:-$dir}"

  local -a all_types
  mapfile -t all_types < <(resolve_with "$type")
  local -a all_files=()
  local t f
  for t in "${all_types[@]}"; do
    if [[ -n "${CUSTOM_TYPE_FILES[$t]+_}" ]]; then
      while IFS= read -r f; do
        f="${f#"${f%%[![:space:]]*}"}"
        f="${f%"${f##*[![:space:]]}"}"
        [[ -z "$f" ]] && continue
        if [[ "$f" != /* ]]; then f="$files_base/$f"; fi
        all_files+=("$f")
      done <<< "${CUSTOM_TYPE_FILES[$t]}"
    fi
  done

  if $RANDOM_ORDER && (( ${#all_files[@]} > 0 )) && command -v shuf >/dev/null 2>&1; then
    mapfile -t all_files < <(printf '%s\n' "${all_files[@]}" | shuf)
  fi

  local file
  for file in "${all_files[@]}"; do
    if [[ ! -f "$file" ]]; then
      if $SHOW_IGNORED; then printf 'SKIP [missing]: %s\n' "$file" >&2; fi
      SKIP_COUNT=$((SKIP_COUNT + 1))
      continue
    fi

    local base=${file##*/}
    local fsize fwords
    fsize=$(($(wc -c < "$file")))
    fwords=$(($(wc -w < "$file")))
    total_bytes=$((total_bytes + fsize))
    total_words=$((total_words + fwords))

    if [[ $MAX_TOKENS -gt 0 ]]; then
      local running
      running=$(tok_est_nums "$total_bytes" "$total_words")
      if (( running > MAX_TOKENS )); then
        printf '\n--- TOKEN BUDGET REACHED (%s tokens) ---\n' "$(fmt_num "$MAX_TOKENS")" >&2
        break
      fi
    fi

    local ext toks
    _file_ext "$base"; ext=$_ext
    toks=$(( fsize * 100 / 680 + fwords * 65 / 100 ))
    EXT_CNT[$ext]=$(( ${EXT_CNT[$ext]:-0} + 1 ))
    EXT_TOK[$ext]=$(( ${EXT_TOK[$ext]:-0} + toks ))
    FILE_COUNT=$((FILE_COUNT + 1))

    local -a hdr_lines
    mapfile -n2 -t hdr_lines < "$file" 2>/dev/null || true
    if [[ ${hdr_lines[0]:-} != *"$file"* && ${hdr_lines[1]:-} != *"$file"* \
       && ${hdr_lines[0]:-} != *"$base"* && ${hdr_lines[1]:-} != *"$base"* ]]; then
      printf '### %s\n' "$file"
    fi
    tr -d '\0' < "$file"; printf '\n\n'
  done
}

# ── Usage ──────────────────────────────────────────────────────────
usage() {
  cat >&2 <<'EOF'
kontext-cli (ktx) - CLI context grabber
Usage:
    ktx [options] [modifiers...] [dir] [.type]

Options:
  -o, --output [FILE]  Write to file (no arg = stdout)
  -l, --limit N        Token limit (default = unlimited)
  -r, --randomize      Randomize file order
  -T, --no-tree        Skip directory tree
  -t, --trace          Show skipped files on stderr
  -c, --config FILE    Config file (default: nearest .ktxrc)
  --raw                No instruction header, no AGENTS.md
  --no-clip            Skip clipboard
  -v, --version        Show version
  -h, --help           Show help

Modifiers: +ITEM includes files, -ITEM excludes.
  Globs (*, ?, []):  +'*.sql'   include SQL files
                     -'*.md'    stop including markdown
  Plain names:       -'dist'    stop skipping dist/ directory
                     +'.env'    force-include (overrides blocklist)

Types: .default, .js, .py (built-in). Define custom types in .ktxrc.
Custom types support with= to compose other types.
See .ktxrc.example for Go, Rust, C/C++, Java and file-list examples.

Examples:
  ktx                        current dir, default type
  ktx .py                    Python project → clipboard
  ktx src/ .js               JS/TS in src/
  ktx .py -l 50000           ~50k token limit
  ktx .py -r -l 50000        random sample within limit
  ktx .py +'*.sql' -'*.md'   add SQL, drop markdown
  ktx .py -o ctx.txt         file output + clipboard
  ktx -o                     stdout only (no clipboard)
EOF
}

# ── Main ───────────────────────────────────────────────────────────
main() {
  local no_clip=false
  local -a MODS=() POSITIONAL=()

  while [[ $# -gt 0 ]]; do
    case $1 in
      -h|--help)         usage; exit 0 ;;
      -v|--version)      echo "ktx $VERSION"; exit 0 ;;
      -o|--output)
        OUT_TO_FILE=true
        if [[ $# -gt 1 && ! "$2" =~ ^- && ! "$2" =~ ^\+ && ! "$2" =~ ^\. && ! -d "$2" ]]; then
          OUT_FILE=$2
          shift 2
        else
          shift
        fi
        ;;
      -l|--limit)        [[ $# -gt 1 ]] && MAX_TOKENS=$2 || { usage; exit 1; }; shift 2 ;;
      -r|--random|--randomize) RANDOM_ORDER=true; shift ;;
      -T|--no-tree)      USE_TREE=false; shift ;;
      -t|--trace)        SHOW_IGNORED=true; shift ;;
      -c|--config)       [[ $# -gt 1 ]] && CONFIG_FILE=$2 || { usage; exit 1; }; shift 2 ;;
      --raw)             RAW_MODE=true; shift ;;
      --no-clip)         no_clip=true; shift ;;
      --)                shift; break ;;
      +*) MODS+=("$1"); shift ;;
      -*)
        local _body="${1:1}"
        if [[ $_body =~ ^[a-zA-Z] && ! $_body == *[\*\?\[\.]* && ${#_body} -le 2 ]]; then
          echo "Unknown option: $1" >&2; usage; exit 1
        else
          MODS+=("$1")
        fi
        shift
        ;;
      *)  POSITIONAL+=("$1"); shift ;;
    esac
  done

  while [[ $# -gt 0 ]]; do
    POSITIONAL+=("$1")
    shift
  done

  local input="." type_override=""
  case ${#POSITIONAL[@]} in
    0) ;;
    1) input="${POSITIONAL[0]}" ;;
    *)
      input="${POSITIONAL[0]}"
      local p
      for p in "${POSITIONAL[@]:1}"; do
        if [[ $p == .* && ${#p} -gt 1 ]]; then type_override="${p#.}"; fi
      done
      ;;
  esac

  local dir type
  if [[ -n $type_override ]]; then
    dir="$input"; type="$type_override"
  else
    local _basename
    _basename="${input##*/}"
    [[ -z "$_basename" ]] && _basename="$input"

    local pd="${_basename%.*}" pt="${_basename##*.}"
    [[ -z $pd ]] && pd='.'

    if [[ -z $pt || $pt == "$_basename" ]]; then
      dir="$input"; type=default
    elif [[ -d "$input" ]]; then
      dir="$input"; type=default
    else
      local _dir_part="${input%.*}"
      [[ -z "$_dir_part" ]] && _dir_part='.'
      if [[ -d "$_dir_part" ]]; then
        dir="$_dir_part"; type="$pt"
      else
        dir="$input"; type=default
      fi
    fi
  fi

  [[ -d $dir ]] || { echo "Directory '$dir' not found" >&2; exit 1; }

  local rc_file=""
  if [[ -n $CONFIG_FILE ]]; then
    rc_file="$CONFIG_FILE"
  else
    rc_file=$(find_ktxrc "$dir") || true
  fi
  # FIX: use if/then so load_ktxrc is never the right-hand side of &&
  # where set -e would kill the script if the function returned non-zero.
  if [[ -n $rc_file ]]; then
    load_ktxrc "$rc_file"
  fi

  # Use type from .ktxrc only if CLI did not specify one
  if [[ $type == default && -n $_TYPE_FROM_RC ]]; then
    type="$_TYPE_FROM_RC"
  fi

  # Apply config modifiers and then CLI modifiers to the effective type
  if (( ${#RC_MODS[@]} > 0 )); then
    apply_mods "$type" "${RC_MODS[@]}"
  fi
  if (( ${#MODS[@]} > 0 )); then
    apply_mods "$type" "${MODS[@]}"
  fi

  local is_filelist=false
  if [[ -n "${CUSTOM_TYPE_FILES[$type]+_}" ]]; then
    is_filelist=true
  elif [[ -z "${INCLUDE_PATTERNS[$type]+_}" ]]; then
    echo "Unknown type '.$type'" >&2; exit 1
  fi

  if ! $is_filelist && [[ -n "${CUSTOM_TYPE_WITH[$type]-}" ]]; then
    _merge_pattern_type "$type"
  fi

  local tmp full_path
  tmp=$(mktemp)
  full_path=$(cd "$dir" >/dev/null 2>&1 && pwd)

  if ! $RAW_MODE; then
    if $AGENT_HEADER_SET; then
      if [[ -n $AGENT_HEADER ]]; then printf '%s\n\n' "$AGENT_HEADER" >> "$tmp"; fi
    else
      printf '%s\n\n' "$DEFAULT_HEADER" >> "$tmp"
    fi
  fi

  printf '## Context for %s\n\n' "$full_path" >> "$tmp"

  if $USE_TREE && ! $is_filelist; then
    run_tree "$dir" "$type" >> "$tmp"
  fi

  if ! $RAW_MODE && [[ -f "$dir/AGENTS.md" ]]; then
    printf '### System Prompt (from AGENTS.md)\n' >> "$tmp"
    cat "$dir/AGENTS.md" >> "$tmp"
    printf '\n\n' >> "$tmp"
  fi

  if $is_filelist; then
    run_files "$dir" "$type" >> "$tmp"
  else
    run_find "$dir" "$type" >> "$tmp"
  fi

  local content
  content=$(<"$tmp")
  rm -f "$tmp"

  if (( FILE_COUNT == 0 )); then
    echo "No files found" >&2
    exit 0
  fi

  # ── Deliver output ------------------------------------------------
  local -a dests=()

  if $OUT_TO_FILE && [[ -z $OUT_FILE ]]; then
    dests+=(stdout)
    printf '%s\n' "$content"
  else
    if ! $no_clip; then
      if copy_to_clipboard "$content"; then
        dests+=(clipboard)
      fi
    fi
    if [[ -n $OUT_FILE ]]; then
      printf '%s\n' "$content" > "$OUT_FILE"
      dests+=("file:$OUT_FILE")
    fi
    if (( ${#dests[@]} == 0 )); then
      printf '%s\n' "$content"
      dests+=(stdout)
    fi
  fi

  local total_toks=0
  for ext in "${!EXT_TOK[@]}"; do
    total_toks=$((total_toks + EXT_TOK[ext]))
  done

  show_stats

  # Test suite relies on this context summary formatting to standard error
  printf '\nContext for: type: %s, files: %d, tokens: %s\n' "$type" "$FILE_COUNT" "$(fmt_num "$total_toks")" >&2
}

main "$@"
